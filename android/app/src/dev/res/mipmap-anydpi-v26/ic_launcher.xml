<?xml version="1.0" encoding="utf-8"?>
<!--
  Dev-flavor adaptive launcher icon for the "Test Mosquito Alert" build.
  Uses the legacy bitmap (src/dev/res/mipmap-*/ic_launcher.png, derived from
  the iOS DevTF AppIconDev 1024x1024 source) as the foreground over a neutral
  gray background, to make the test build visually distinguishable from the
  production "Mosquito Alert" launcher icon.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@android:color/darker_gray"/>
    <foreground>
        <inset
            android:drawable="@mipmap/ic_launcher"
            android:inset="15%" />
    </foreground>
</adaptive-icon>
